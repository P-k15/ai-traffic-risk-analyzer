# Copy this file to .env and fill in your own values.
# .env is git-ignored and will never be committed.

# Generate one at https://djecrety.ir/ or with:
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=replace-with-a-real-random-secret-key

# Set to False in production
DEBUG=False

# Comma-separated list of domains this app is served from
ALLOWED_HOSTS=127.0.0.1,localhost,yourapp.onrender.com

# Comma-separated list, needed if DEBUG=False and you use forms/POST (scheme+host, no path)
CSRF_TRUSTED_ORIGINS=https://yourapp.onrender.com

GOOGLE_MAPS_API_KEY=your-google-maps-api-key
